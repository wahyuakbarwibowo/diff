{
  "name": "devtools-offline",
  "version": "0.1.0",
  "private": true,
  "description": "Offline browser-based developer tools with an optional local server CLI.",
  "type": "module",
  "bin": {
    "devtools-offline": "./bin/devtools.js"
  },
  "scripts": {
    "start": "node ./bin/devtools.js",
    "serve": "node ./bin/devtools.js serve",
    "check": "node ./scripts/check-pages.mjs && node ./scripts/check-cli.mjs"
  },
  "engines": {
    "node": ">=18"
  }
}
